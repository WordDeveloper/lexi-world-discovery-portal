# ─────────────────────────────────────────────────────────────
# Lexi World Discovery Portal — Environment Variables
# Copy to .env.local for local dev, and set these in Vercel for prod.
# ─────────────────────────────────────────────────────────────

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (https://resend.com/api-keys)
RESEND_API_KEY=re_your_key
# Verified sender + where submissions are delivered
MAIL_FROM="Lexi World Discovery <discovery@yourdomain.com>"
MAIL_TO="team@yourdomain.com"

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Passphrase that protects /admin (set a long random string)
ADMIN_ACCESS_TOKEN=change-me-to-a-long-random-string

# Optional: enable the AI assistant's "suggest an example" via an LLM.
# If unset, the assistant still works using the built-in reference library.
OPENAI_API_KEY=
